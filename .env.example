# Database
POSTGRES_DB=training_plan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://postgres:changeme@db:5432/training_plan

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production

# Admin seed (run: docker compose exec api npm run db:seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123

# Frontend (used in docker-compose for nginx proxy)
VITE_API_URL=/api

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Strava OAuth
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:3001/api/strava/callback
STRAVA_LOGIN_REDIRECT_URI=http://localhost:3001/api/strava/login-callback
FRONTEND_URL=http://localhost:5173
