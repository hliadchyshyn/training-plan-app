FROM node:20-alpine

WORKDIR /workspace

# Copy all package.json files so npm can resolve workspaces
COPY package.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

RUN npm install

WORKDIR /workspace/apps/web

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
